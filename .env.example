# NEXUS AI Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# OPENAI API CONFIGURATION (REQUIRED)
# ============================================
OPENAI_API_KEY=sk-your-api-key-here

# ============================================
# AGENT LIMITS & THRESHOLDS
# ============================================

# Maximum number of iterations per task execution
MAX_ITERATIONS=15

# Maximum tokens per task (prevents excessive API costs)
MAX_TOKENS_PER_TASK=15000

# API request timeout in seconds
REQUEST_TIMEOUT=15

# Maximum number of memory items to retain
MEMORY_SIZE=20

# Trigger reflection every N iterations
REFLECTION_THRESHOLD=3

# Trigger evolution every N iterations
EVOLUTION_THRESHOLD=5

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server host binding
HOST=0.0.0.0

# Server port
PORT=8000

# Enable streaming responses (Server-Sent Events)
STREAMING_ENABLED=true

# Directory for persistent knowledge storage
PERSISTENCE_DIR=./nexus_data

# ============================================
# OPTIONAL: ADVANCED SETTINGS
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Environment: development, staging, production
ENVIRONMENT=development

# Enable detailed logging
DEBUG=false
